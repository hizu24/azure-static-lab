{
  "routes": [
    {
      "route": "/public.html",
      "allowedRoles": ["anonymous", "authenticated"]
    },
    {
      "route": "/member.html",
      "allowedRoles": ["authenticated"]
    },
    {
      "route": "/admin.html",
      "allowedRoles": ["admin"]
    },
    {
      "route": "/*",
      "allowedRoles": ["authenticated"]
    }
  ],
  "responseOverrides": {
    "401": {
      "statusCode": 302,
      "redirect": "/.auth/login/aad"
    },
    "403": {
      "statusCode": 302,
      "redirect": "/member.html"
    }
  }
}
